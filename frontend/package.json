{
  "services": [
    {
      "name": "fwip-frontend",
      "build": {
        "builder": "node",
        "buildCommand": "npm install && npm run build",
        "startCommand": "npm run start",
        "rootDirectory": "frontend"
      },
      "env": [
        { "key": "NEXT_PUBLIC_API_URL", "value": "https://fwip-backend.railway.app" }
      ]
    },
    {
      "name": "fwip-backend",
      "build": {
        "builder": "node",
        "buildCommand": "npm install && npm run build",
        "startCommand": "npm run start",
        "rootDirectory": "backend"
      },
      "env": [
        { "key": "DATABASE_URL", "value": "<your_database_url>" },
        { "key": "STRAPI_ADMIN_JWT_SECRET", "value": "<secret_here>" }
      ]
    }
  ]
}
